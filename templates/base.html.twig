<!doctype html>

<html lang="{{ app.request.locale }}" class="scroll-smooth">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        {% block meta %}
            {% block meta_robots %}{% endblock %}
            <meta name="description" content="{% block meta_description %}{{ 'meta.description'|trans }}{% endblock %}" />
            <meta property="og:type" content="website" />
            <meta property="og:locale" content="{{ app.request.locale == 'en' ? 'en_US' : 'de_DE' }}" />
            <meta property="og:locale:alternate" content="{{ app.request.locale == 'en' ? 'de_DE' : 'en_US' }}" />
            <meta property="og:url" content="https://www.marcelkraus.de{{ app.request.pathInfo == '/' ? '' : app.request.pathInfo }}" />
            <meta property="og:title" content="{{ block('title') }}" />
            <meta property="og:description" content="{{ block('meta_description') }}" />
            <meta property="og:image" content="https://www.marcelkraus.de/images/sharing.jpg" />
            <meta property="og:image:width" content="1200" />
            <meta property="og:image:height" content="630" />
            <meta property="og:image:alt" content="{{ 'meta.image_alt'|trans }}" />
            <meta name="twitter:card" content="summary_large_image" />
            <meta name="twitter:title" content="{{ block('title') }}" />
            <meta name="twitter:description" content="{{ block('meta_description') }}" />
            <meta name="twitter:image" content="https://www.marcelkraus.de/images/sharing.jpg" />
            <meta name="twitter:image:alt" content="{{ 'meta.image_alt'|trans }}" />
            <link rel="canonical" href="https://www.marcelkraus.de{{ app.request.pathInfo == '/' ? '' : app.request.pathInfo }}" />
            {% set de_route = switch_route|replace({'_en_': '_de_'}) %}
            {% set en_route = switch_route|replace({'_de_': '_en_'}) %}
            <link rel="alternate" hreflang="de" href="https://www.marcelkraus.de{{ path(de_route) }}" />
            <link rel="alternate" hreflang="en" href="https://www.marcelkraus.de{{ path(en_route) }}" />
            <link rel="alternate" hreflang="x-default" href="https://www.marcelkraus.de/" />
            <script type="application/ld+json">
                {
                    "@context": "https://schema.org",
                    "@type": "Person",
                    "name": "Marcel Kraus",
                    "jobTitle": "{{ 'hero.job_title'|trans }}",
                    "url": "https://www.marcelkraus.de",
                    "image": "https://www.marcelkraus.de/images/avatar.jpg",
                    "address": {
                        "@type": "PostalAddress",
                        "addressLocality": "Erftstadt",
                        "addressRegion": "Nordrhein-Westfalen",
                        "addressCountry": "DE"
                    },
                    "knowsAbout": ["3D Printing", "App Development", "Apple", "C", "C++", "iOS", "iPadOS", "Objective-C", "Oldtimer Restoration", "PHP", "Swift", "Symfony", "Web Development"]
                }
            </script>
        {% endblock %}
        {% block stylesheets %}{% endblock %}
        <link rel="stylesheet" href="/css/output.css">
        <title>{% block title %}{{ 'meta.title'|trans }}{% endblock %}</title>
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('apple-touch-icon.png') }}">
        <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('favicon-32x32.png') }}">
        <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('favicon-16x16.png') }}">

        <meta name="theme-color" content="#FAFAFA" media="(prefers-color-scheme: light)">
        <meta name="theme-color" content="#0A0A0A" media="(prefers-color-scheme: dark)">
        {% block javascript %}
            <script>
                var _paq = window._paq = window._paq || [];
                _paq.push(["disableCookies"]);
                _paq.push(['trackPageView']);
                _paq.push(['enableLinkTracking']);
                (function() {
                    var u="https://matomo.marcelkraus.de/";
                    _paq.push(['setTrackerUrl', u+'matomo.php']);
                    _paq.push(['setSiteId', '10']);
                    var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
                    g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
                })();
            </script>
        {% endblock %}
    </head>
    <body class="bg-surface dark:bg-surface-dark text-foreground dark:text-foreground-dark antialiased">
        <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[60] focus:px-4 focus:py-2 focus:rounded-lg focus:bg-accent focus:text-on-accent focus:text-sm focus:font-medium">{{ 'skip_to_content'|trans }}</a>
        <header class="fixed top-0 left-0 right-0 z-50 h-20 bg-surface/80 dark:bg-surface-dark/80 backdrop-blur-sm border-b border-border dark:border-border-dark">
            <div class="max-w-6xl mx-auto h-full px-8 flex items-center justify-between">
            <a href="{{ app.request.locale == 'en' ? '/en' : '/' }}" data-nav="hero" class="flex items-center text-foreground dark:text-foreground-dark" aria-label="{{ 'aria_homepage'|trans }}">
                <svg viewBox="0 0 1070 263" class="h-10 w-auto" xmlns="http://www.w3.org/2000/svg" style="fill-rule:evenodd;clip-rule:evenodd;stroke-linejoin:round;stroke-miterlimit:2;" aria-hidden="true">
                    <g transform="matrix(1.51541,0,0,1.51541,-1445.83,-236.515)">
                        <g transform="matrix(1.55362,0,0,1.04498,285.877,-424.496)">
                            <path d="M557.521,678.716L557.521,716.605C557.521,719.218 556.093,721.341 554.335,721.341L528.851,721.341C527.093,721.341 525.665,719.218 525.665,716.605L525.665,678.716C525.665,676.102 527.093,673.98 528.851,673.98L554.335,673.98C556.093,673.98 557.521,676.102 557.521,678.716Z" style="fill:rgb(234,88,12);"/>
                        </g>
                        <g transform="matrix(1.55362,0,0,1.04498,211.64,-424.496)">
                            <path d="M557.521,678.716L557.521,716.605C557.521,719.218 556.093,721.341 554.335,721.341L528.851,721.341C527.093,721.341 525.665,719.218 525.665,716.605L525.665,678.716C525.665,676.102 527.093,673.98 528.851,673.98L554.335,673.98C556.093,673.98 557.521,676.102 557.521,678.716Z" style="fill:rgb(34,197,94);"/>
                        </g>
                        <g transform="matrix(1.55362,0,0,1.04498,137.403,-424.496)">
                            <path d="M557.521,678.716L557.521,716.605C557.521,719.218 556.093,721.341 554.335,721.341L528.851,721.341C527.093,721.341 525.665,719.218 525.665,716.605L525.665,678.716C525.665,676.102 527.093,673.98 528.851,673.98L554.335,673.98C556.093,673.98 557.521,676.102 557.521,678.716Z" style="fill:rgb(21,94,117);"/>
                        </g>
                    </g>
                    <g transform="matrix(1.00169,0,0,1.00134,-584.182,-511.066)">
                        <text x="567.199px" y="657.784px" style="font-family:'Aller', sans-serif;font-size:200px;fill:currentColor;">mar<tspan x="912.799px 1005.4px 1116.6px" y="657.784px 657.784px 657.784px">cel</tspan>kr<tspan x="1351.4px 1454.8px" y="657.784px 657.784px">au</tspan>s</text>
                    </g>
                </svg>
            </a>
            <div id="header-controls" class="hidden sm:flex sm:flex-row sm:items-center sm:gap-6">
                {% block header_nav %}{% endblock %}
                <div class="flex items-center gap-1 text-sm sm:text-xs text-muted">
                    <button type="button" id="btn-dark" onclick="setColorMode('dark')" aria-pressed="false" class="transition-colors duration-300 hover:text-foreground dark:hover:text-foreground-dark">{{ 'theme.night'|trans }}</button>
                    <span>·</span>
                    <button type="button" id="btn-light" onclick="setColorMode('light')" aria-pressed="true" class="transition-colors duration-300 hover:text-foreground dark:hover:text-foreground-dark">{{ 'theme.day'|trans }}</button>
                </div>
                <div class="flex items-center gap-1 text-sm sm:text-xs sm:border-l sm:border-border sm:dark:border-border-dark sm:pl-6 text-muted">
                    {% if app.request.locale == 'de' %}
                        <span class="text-foreground dark:text-foreground-dark font-medium">DE</span>
                        <span>&middot;</span>
                        <a href="{{ path(switch_route) }}" class="hover:text-foreground dark:hover:text-foreground-dark transition-colors duration-300" onclick="document.cookie='locale=en;path=/;max-age=31536000;SameSite=Lax'">EN</a>
                    {% else %}
                        <a href="{{ path(switch_route) }}" class="hover:text-foreground dark:hover:text-foreground-dark transition-colors duration-300" onclick="document.cookie='locale=de;path=/;max-age=31536000;SameSite=Lax'">DE</a>
                        <span>&middot;</span>
                        <span class="text-foreground dark:text-foreground-dark font-medium">EN</span>
                    {% endif %}
                </div>
            </div>
            <button type="button" id="btn-menu" onclick="toggleMobileMenu()" aria-label="{{ 'nav.menu'|trans }}" aria-expanded="false" aria-controls="header-controls" class="sm:hidden -m-2 p-2 text-muted hover:text-foreground dark:hover:text-foreground-dark transition-colors duration-300">
                <svg id="icon-menu-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
                <svg id="icon-menu-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
            </div>
        </header>
        <script>
            // Color mode
            function setColorMode(mode) {
                localStorage.setItem('colorMode', mode);
                document.documentElement.classList.toggle('dark', mode === 'dark');
                updateColorModeButtons();
            }

            function updateColorModeButtons() {
                const isDark = document.documentElement.classList.contains('dark');
                const btnDark = document.getElementById('btn-dark');
                const btnLight = document.getElementById('btn-light');
                if (btnDark) {
                    btnDark.classList.toggle('text-foreground', isDark);
                    btnDark.classList.toggle('dark:text-foreground-dark', isDark);
                    btnDark.classList.toggle('font-medium', isDark);
                    btnDark.setAttribute('aria-pressed', isDark);
                }
                if (btnLight) {
                    btnLight.classList.toggle('text-foreground', !isDark);
                    btnLight.classList.toggle('dark:text-foreground-dark', !isDark);
                    btnLight.classList.toggle('font-medium', !isDark);
                    btnLight.setAttribute('aria-pressed', !isDark);
                }
            }

            (function () {
                const saved = localStorage.getItem('colorMode');
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                const useDark = saved === 'dark' || (!saved && prefersDark);
                document.documentElement.classList.toggle('dark', useDark);
                // Sync the toggle's aria-pressed/active state before first paint.
                updateColorModeButtons();
            })();

            document.addEventListener('DOMContentLoaded', updateColorModeButtons);
        </script>
        <script>
            document.addEventListener('click', (e) => {
                const navLink = e.target.closest('[data-nav]');
                if (navLink == null) {
                    return;
                }
                const target = document.getElementById(navLink.dataset.nav);
                if (target) {
                    e.preventDefault();
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        </script>
        <script>
            // Mobile header menu: sections, theme and language live in
            // #header-controls and drop down below the right-aligned burger.
            function setMenuState(isOpen) {
                const button = document.getElementById('btn-menu');
                if (button) {
                    button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                }
                const iconOpen = document.getElementById('icon-menu-open');
                const iconClose = document.getElementById('icon-menu-close');
                if (iconOpen) {
                    iconOpen.classList.toggle('hidden', isOpen);
                }
                if (iconClose) {
                    iconClose.classList.toggle('hidden', isOpen === false);
                }
            }

            function toggleMobileMenu() {
                const controls = document.getElementById('header-controls');
                if (controls.classList.contains('mobile-open')) {
                    closeMobileMenu(true);
                    return;
                }
                controls.classList.add('mobile-open');
                setMenuState(true);
                // Move focus into the open menu for keyboard/screenreader users.
                const firstItem = controls.querySelector('a, button');
                if (firstItem) {
                    firstItem.focus();
                }
            }

            function closeMobileMenu(returnFocus) {
                const controls = document.getElementById('header-controls');
                const button = document.getElementById('btn-menu');
                if (controls) {
                    controls.classList.remove('mobile-open');
                }
                setMenuState(false);
                if (returnFocus === true && button) {
                    button.focus();
                }
            }

            // Close on outside click (but keep open when toggling theme/language).
            document.addEventListener('click', (event) => {
                const controls = document.getElementById('header-controls');
                const button = document.getElementById('btn-menu');
                if (controls == null || controls.classList.contains('mobile-open') === false) {
                    return;
                }
                if (controls.contains(event.target) || (button && button.contains(event.target))) {
                    return;
                }
                closeMobileMenu();
            });

            // Escape closes only the menu (when open) and returns focus to the button.
            document.addEventListener('keydown', (event) => {
                if (event.key !== 'Escape') {
                    return;
                }
                const controls = document.getElementById('header-controls');
                if (controls && controls.classList.contains('mobile-open')) {
                    closeMobileMenu(true);
                }
            });

            // Reset the menu when growing past the mobile breakpoint.
            window.matchMedia('(min-width: 640px)').addEventListener('change', (event) => {
                if (event.matches) {
                    closeMobileMenu();
                }
            });
        </script>
        <script>
            // Assemble e-mail links spam-safe from data attributes; no raw
            // address sits in the markup. A text element carrying
            // `data-email-text` is turned into a mailto link with the address
            // as its text; any other element with `data-email-user` (e.g. an
            // icon link) only gets its href set.
            document.addEventListener('DOMContentLoaded', () => {
                document.querySelectorAll('[data-email-user]').forEach((element) => {
                    const address = element.dataset.emailUser + '@' + element.dataset.emailDomain;
                    if (element.tagName === 'A') {
                        element.href = 'mailto:' + address;
                        if (element.dataset.emailText !== undefined) {
                            element.textContent = address;
                        }
                    } else {
                        const link = document.createElement('a');
                        link.href = 'mailto:' + address;
                        link.textContent = address;
                        link.className = element.className;
                        element.replaceWith(link);
                    }
                });
            });
        </script>
        {% block body %}
            <main id="main-content">
                {% block content %}{% endblock %}
            </main>
        {% endblock %}
        <footer class="bg-surface dark:bg-surface-dark border-t border-border dark:border-border-dark text-xs text-muted">
            <div class="max-w-6xl mx-auto px-8 py-4 sm:py-0 sm:h-14 flex items-center justify-between gap-3">
            <div class="flex flex-col leading-tight">
                <span>&copy; {{ "now" | date("Y") }} Marcel Kraus</span>
                <span>{{ 'footer.notice'|trans }}</span>
            </div>
            <div class="flex items-center gap-4">
                {% include 'partials/social_links.html.twig' with { wrapperClass: 'hidden sm:flex items-center gap-4', iconClass: 'w-4 h-4' } %}
                <span class="hidden sm:inline-block w-px h-4 bg-border dark:bg-border-dark"></span>
                <a href="{{ path(app.request.locale == 'en' ? 'app_en_imprint' : 'app_de_imprint') }}" class="hover:text-foreground dark:hover:text-foreground-dark transition-colors duration-300">{{ 'footer.imprint'|trans }}</a>
                <a href="{{ path(app.request.locale == 'en' ? 'app_en_data_privacy' : 'app_de_data_privacy') }}" class="hover:text-foreground dark:hover:text-foreground-dark transition-colors duration-300">{{ 'footer.data_privacy'|trans }}</a>
            </div>
            </div>
        </footer>
    </body>
</html>
